# Agency OS API
HOST=127.0.0.1
PORT=8787
AGENCY_OS_CORS_ORIGIN=*

# LLM (optional; fallback templates are used if missing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4.6
INTELLIGENCE_PRIMARY_PROVIDER=auto
INTELLIGENCE_RESEARCH_PROVIDER=auto
INTELLIGENCE_STRATEGY_PROVIDER=auto
INTELLIGENCE_EXECUTION_PROVIDER=auto
MARKET_RESEARCH_WITH_WEB=true

# Database
AGENCY_OS_DB_PATH=apps/agency-marketing-os/data/agency_os.db
AGENCY_OS_ENCRYPTION_KEY=replace-with-32-char-secret

# Task sync integrations
TASK_SYNC_PROVIDER=none
TASK_SYNC_WEBHOOK_URL=
TASK_SYNC_WEBHOOK_TOKEN=
TASK_SYNC_MCP_TOOL=zapier

# MCP bridge settings used by Agency OS API
MCP_PROXY_URL=http://127.0.0.1:4000
MCP_PROXY_TOKEN=local-dev-token

# MCP Proxy
MCP_PROXY_HOST=127.0.0.1
MCP_PROXY_PORT=4000
MCP_PROXY_MODE=direct
MCP_PROXY_TIMEOUT_MS=15000
MCP_PROXY_CORS_ORIGIN=*

# Google service account credentials for GA4 + GSC direct adapters
# Option A: inline JSON
GOOGLE_SERVICE_ACCOUNT_JSON=
# Option B: file path
GOOGLE_SERVICE_ACCOUNT_FILE=

# GA4 direct adapter
GA4_PROPERTY_ID=

# Google Search Console direct adapter
GSC_SITE_URL=sc-domain:example.com

# SEMrush direct adapter
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
SEMRUSH_API_BASE_URL=https://api.semrush.com

# Ahrefs direct adapter
AHREFS_API_KEY=
AHREFS_API_BASE_URL=https://apiv2.ahrefs.com

# Google Ads direct adapter
GOOGLE_ADS_API_VERSION=v18
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Meta Ads direct adapter
META_GRAPH_VERSION=v21.0
META_AD_ACCOUNT_ID=
META_ACCESS_TOKEN=

# Optional webhook mode:
# Set MCP_PROXY_MODE=webhook and configure the tools you use.
# TOOL_GA4_WEBHOOK_URL=https://your-endpoint.example.com/ga4
# TOOL_GOOGLE_ADS_WEBHOOK_URL=https://your-endpoint.example.com/google-ads
# TOOL_META_ADS_WEBHOOK_URL=https://your-endpoint.example.com/meta-ads
# TOOL_GOOGLE_SEARCH_CONSOLE_WEBHOOK_URL=https://your-endpoint.example.com/gsc
